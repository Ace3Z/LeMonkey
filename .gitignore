# ===== LeMonkey .gitignore =====
# Tracked: code, scripts, configs, READMEs, demo GIFs.
# Local only: datasets, model weights, recordings, internal notes.

# Datasets and model weights (hosted on the Hugging Face Hub)
datasets/
*.safetensors
*.pt
*.pth
*.ckpt

# Per-eval runtime artifacts (scripts are tracked, heavy outputs are not)
eval_1/train/
eval_1/rollouts/
eval_1/evals/
eval_1/bench/
eval_1/SETUP.md
eval_2/train/
eval_2/rollouts/
eval_2/evals/
eval_2/state/
eval_3/train/
eval_3/rollouts/
eval_3/evals/
eval_3/state/
eval_3/outputs/

# Internal notes: kept local, not published to the repo
docs/
CLAUDE.md

# Heavy eval-day video recordings (the READMEs use the GIFs in media/gifs/)
media/videos/

# Third-party dependency installed per machine
third_party/sam2/

# Python, editor, and OS cruft
__pycache__/
*.py[cod]
.DS_Store
.vscode/
.idea/
*.swp

# Claude Code agent state and secrets
.claude/
secrets/
